{
  "info": {
    "name": "TumiPay - PayIn Tests",
    "_postman_id": "2e9ffe6c-4f5f-47f8-91ac-86c20164cd32",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01_happy_path",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Request-ID",
            "value": "{{request_id}}"
          },
          {
            "key": "X-Idempotency-Key",
            "value": "{{idempotency_key}}"
          },
          {
            "key": "X-Merchant-ID",
            "value": "{{merchant_id}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"transaction\": {\n    \"transaction_id\": \"{{transaction_id}}\",\n    \"reference_id\": \"ref-001\",\n    \"amount\": {\n      \"value\": 10000,\n      \"currency\": \"COP\"\n    },\n    \"country\": \"CO\",\n    \"payment_method\": \"CARD\",\n    \"description\": \"Pago de prueba\",\n    \"expiration_minutes\": 30\n  },\n  \"customer\": {\n    \"customer_id\": \"cust-001\",\n    \"document\": {\n      \"document_type\": \"CC\",\n      \"document_number\": \"123456789\"\n    },\n    \"first_name\": \"Juan\",\n    \"last_name\": \"Perez\",\n    \"email\": \"juan@test.com\",\n    \"phone\": \"3001234567\",\n    \"person_type\": \"INDIVIDUAL\"\n  },\n  \"merchant\": {\n    \"merchant_id\": \"m-001\",\n    \"code\": \"TUMIPAY\",\n    \"name\": \"Store\",\n    \"document\": {\n      \"type\": \"NIT\",\n      \"number\": \"900123456\"\n    }\n  },\n  \"redirect_urls\": {\n    \"success_url\": \"https://example.com/success\",\n    \"failed_url\": \"https://example.com/failed\",\n    \"pending_url\": \"https://example.com/pending\"\n  },\n  \"webhook_url\": \"https://example.com/webhook\",\n  \"metadata\": {\n    \"order_id\": \"ORD-999\",\n    \"notes\": \"Pago inicial\"\n  }\n}"
        },
        "url": "{{baseUrl}}/tp/payment/adapter/v1/payin/transaction"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.variables.set('request_id', pm.variables.replaceIn('{{$guid}}'));",
              "pm.variables.set('idempotency_key', pm.variables.replaceIn('{{$guid}}'));",
              "pm.variables.set('transaction_id', pm.variables.replaceIn('{{$guid}}'));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('SUCCESS', () => { pm.expect(json.status).to.eql('SUCCESS'); pm.expect(json.code).to.eql('PROCESS_COMPLETED'); });",
              "pm.environment.set('transaction_id', json.data.transaction_id);",
              "pm.environment.set('adapter_transaction_id', json.data.adapter_transaction_id);",
              "pm.environment.set('provider_transaction_id', json.data.provider_transaction_id);",
              "pm.test('Core fields exist', () => {",
              "  pm.expect(json.data).to.have.property('adapter_transaction_id');",
              "  pm.expect(json.data).to.have.property('provider_transaction_id');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "02_validation_error_country_blank",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"transaction\": {\n    \"country\": \"\"\n  }\n}"
        },
        "url": "{{baseUrl}}/tp/payment/adapter/v1/payin/transaction"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.test('VALIDATION_ERROR', () => {",
              "  pm.expect(json.code).to.eql('VALIDATION_ERROR');",
              "  pm.expect(json.status).to.eql('ERROR');",
              "});",
              "pm.test('Field array present', () => { pm.expect(json.data).to.be.an('array'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "03_idempotency_first_call",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Request-ID",
            "value": "{{request_id}}"
          },
          {
            "key": "X-Idempotency-Key",
            "value": "{{payin_idem_key}}"
          },
          {
            "key": "X-Merchant-ID",
            "value": "{{merchant_id}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"transaction\": {\n    \"transaction_id\": \"{{transaction_id}}\",\n    \"reference_id\": \"ref-idem-001\",\n    \"amount\": {\n      \"value\": 10000,\n      \"currency\": \"COP\"\n    },\n    \"country\": \"CO\",\n    \"payment_method\": \"CARD\",\n    \"description\": \"Test idempotencia primera llamada\",\n    \"expiration_minutes\": 30\n  },\n  \"customer\": {\n    \"customer_id\": \"cust-idem-001\",\n    \"document\": {\n      \"document_type\": \"CC\",\n      \"document_number\": \"123456789\"\n    },\n    \"first_name\": \"Juan\",\n    \"last_name\": \"Perez\",\n    \"email\": \"juan@test.com\",\n    \"phone\": \"3001234567\",\n    \"person_type\": \"INDIVIDUAL\"\n  },\n  \"merchant\": {\n    \"merchant_id\": \"m-001\",\n    \"code\": \"TUMIPAY\",\n    \"name\": \"Store\",\n    \"document\": {\n      \"type\": \"NIT\",\n      \"number\": \"900123456\"\n    }\n  },\n  \"redirect_urls\": {\n    \"success_url\": \"https://example.com/success\",\n    \"failed_url\": \"https://example.com/failed\",\n    \"pending_url\": \"https://example.com/pending\"\n  },\n  \"webhook_url\": \"https://example.com/webhook\",\n  \"metadata\": {\n    \"order_id\": \"ORD-IDEM-001\",\n    \"notes\": \"Primera llamada idempotencia\"\n  }\n}"
        },
        "url": "{{baseUrl}}/tp/payment/adapter/v1/payin/transaction"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const idemKey = pm.variables.replaceIn('{{$guid}}');",
              "pm.environment.set('payin_idem_key', idemKey);",
              "pm.variables.set('request_id', pm.variables.replaceIn('{{$guid}}'));",
              "pm.variables.set('transaction_id', pm.variables.replaceIn('{{$guid}}'));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 on first idempotency call', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('SUCCESS on first idempotency call', () => pm.expect(json.status).to.eql('SUCCESS'));"
            ]
          }
        }
      ]
    },
    {
      "name": "04_idempotency_duplicate",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Request-ID",
            "value": "{{request_id}}"
          },
          {
            "key": "X-Idempotency-Key",
            "value": "{{payin_idem_key}}"
          },
          {
            "key": "X-Merchant-ID",
            "value": "{{merchant_id}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"transaction\": {\n    \"transaction_id\": \"{{transaction_id}}\",\n    \"reference_id\": \"ref-idem-001\",\n    \"amount\": {\n      \"value\": 10000,\n      \"currency\": \"COP\"\n    },\n    \"country\": \"CO\",\n    \"payment_method\": \"CARD\",\n    \"description\": \"Test idempotencia segunda llamada\",\n    \"expiration_minutes\": 30\n  },\n  \"customer\": {\n    \"customer_id\": \"cust-idem-001\",\n    \"document\": {\n      \"document_type\": \"CC\",\n      \"document_number\": \"123456789\"\n    },\n    \"first_name\": \"Juan\",\n    \"last_name\": \"Perez\",\n    \"email\": \"juan@test.com\",\n    \"phone\": \"3001234567\",\n    \"person_type\": \"INDIVIDUAL\"\n  },\n  \"merchant\": {\n    \"merchant_id\": \"m-001\",\n    \"code\": \"TUMIPAY\",\n    \"name\": \"Store\",\n    \"document\": {\n      \"type\": \"NIT\",\n      \"number\": \"900123456\"\n    }\n  },\n  \"redirect_urls\": {\n    \"success_url\": \"https://example.com/success\",\n    \"failed_url\": \"https://example.com/failed\",\n    \"pending_url\": \"https://example.com/pending\"\n  },\n  \"webhook_url\": \"https://example.com/webhook\",\n  \"metadata\": {\n    \"order_id\": \"ORD-IDEM-001\",\n    \"notes\": \"Segunda llamada idempotencia\"\n  }\n}"
        },
        "url": "{{baseUrl}}/tp/payment/adapter/v1/payin/transaction"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.variables.set('request_id', pm.variables.replaceIn('{{$guid}}'));",
              "pm.variables.set('transaction_id', pm.variables.replaceIn('{{$guid}}'));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.test('code es DUPLICATE_TRANSACTION', () => pm.expect(json.code).to.eql('DUPLICATE_TRANSACTION'));",
              "pm.test('status es FAILED', () => pm.expect(json.status).to.eql('FAILED'));",
              "pm.test('message indica clave de idempotencia duplicada', () => {",
              "  pm.expect(json.message).to.include('Duplicate transaction detected');",
              "  pm.expect(json.message).to.include(pm.environment.get('payin_idem_key'));",
              "});"
            ]
          }
        }
      ]
    }
  ]
}