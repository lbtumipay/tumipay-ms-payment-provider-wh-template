    {
      "name": "Health Checks",
      "item": [
        {
          "name": "Get Microservice Info",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test: Validar que la respuesta sea exitosa",
                  "",
                  "pm.test(\"Status code es 200\", function () {",
                  "",
                  "    pm.response.to.have.status(200);",
                  "",
                  "});",
                  "",
                  "",
                  "",
                  "// Test: Validar que el cuerpo de la respuesta contiene los campos esperados (BaseApiResponse)",
                  "",
                  "pm.test(\"La respuesta contiene la estructura BaseApiResponse\", function () {",
                  "",
                  "    var jsonData = pm.response.json();",
                  "",
                  "    pm.expect(jsonData).to.have.property('code');",
                  "",
                  "    pm.expect(jsonData).to.have.property('status');",
                  "",
                  "    pm.expect(jsonData).to.have.property('message');",
                  "",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "",
                  "});",
                  "",
                  "",
                  "",
                  "// Test: Validar que el status es SUCCESS",
                  "",
                  "pm.test(\"El status indica éxito\", function () {",
                  "",
                  "    var jsonData = pm.response.json();",
                  "",
                  "    pm.expect(jsonData.status).to.equal('SUCCESS');",
                  "",
                  "});",
                  "",
                  "",
                  "",
                  "// Test: Validar los campos de datos del servicio",
                  "",
                  "pm.test(\"Los datos contienen los campos del servicio\", function () {",
                  "",
                  "    var jsonData = pm.response.json();",
                  "",
                  "    pm.expect(jsonData.data).to.have.property('serviceName');",
                  "",
                  "    pm.expect(jsonData.data).to.have.property('serviceDescription');",
                  "",
                  "    pm.expect(jsonData.data).to.have.property('version');",
                  "",
                  "    pm.expect(jsonData.data).to.have.property('environment');",
                  "",
                  "    pm.expect(jsonData.data).to.have.property('javaVersion');",
                  "",
                  "    pm.expect(jsonData.data).to.have.property('springBootVersion');",
                  "",
                  "    pm.expect(jsonData.data).to.have.property('timestamp');",
                  "",
                  "});",
                  "",
                  "",
                  "",
                  "// Test: Validar el tipo de datos",
                  "",
                  "pm.test(\"Los datos tienen los tipos correctos\", function () {",
                  "",
                  "    var jsonData = pm.response.json();",
                  "",
                  "    pm.expect(jsonData.data.serviceName).to.be.a('string');",
                  "",
                  "    pm.expect(jsonData.data.serviceDescription).to.be.a('string');",
                  "",
                  "    pm.expect(jsonData.data.version).to.be.a('string');",
                  "",
                  "    pm.expect(jsonData.data.environment).to.be.a('string');",
                  "",
                  "    pm.expect(jsonData.data.javaVersion).to.be.a('string');",
                  "",
                  "    pm.expect(jsonData.data.springBootVersion).to.be.a('string');",
                  "",
                  "});",
                  "",
                  "",
                  "",
                  "// Guardar los valores en variables de entorno",
                  "",
                  "pm.test(\"Guardar información en variables de entorno\", function () {",
                  "",
                  "    var jsonData = pm.response.json();",
                  "",
                  "    pm.environment.set('serviceName', jsonData.data.serviceName);",
                  "",
                  "    pm.environment.set('serviceVersion', jsonData.data.version);",
                  "",
                  "    pm.environment.set('serviceEnvironment', jsonData.data.environment);",
                  "",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
