root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = false
max_line_length = 240
tab_width = 4

[{*.bash,*.sh,*.zsh}]
indent_size = 4
tab_width = 4

[{*.har,*.jsb2,*.jsb3,*.json,.babelrc,.eslintrc,.stylelintrc,bowerrc,jest.config}]
indent_size = 4

[{*.yaml,*.yml}]
indent_size = 4

[{*.cmd, *.bat}]
end_of_line = crlf